PORT=5000

# 生产环境前端来源（逗号分隔）
# ALLOWED_ORIGINS=https://example.com,https://www.example.com

# Database (portable default)
DATABASE_URI=sqlite:///./Data/campus_qa.db
STORAGE_MODE=chroma

# Vector / graph options
VECTOR_STORAGE_DIM=512
SQL_SERVER_VECTOR_DIM=512
EMBEDDING_VECTOR_DIM=512
KNOWLEDGE_GRAPH_SYNC=true
KNOWLEDGE_GRAPH_RAG_EXPAND=true
KNOWLEDGE_GRAPH_CHROMA_SYNC=true
ENTITY_QUERY_AUGMENT=true
KNOWLEDGE_ARCHIVE_FILES=true
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_MODEL_DIR=Backend/Models/embedding/bge-small-zh-v1.5
EMBEDDING_HF_ENDPOINT=https://hf-mirror.com
EMBEDDING_REMOTE_DOWNLOAD_ENABLED=true

# Security
JWT_SECRET_KEY=change_this_to_a_secure_random_key_at_least_32_bytes_long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES=1800
JWT_REFRESH_TOKEN_EXPIRES=604800
ADMIN_SECONDARY_PASSWORD_HASH=

# LLM（hunyuan|auto，解析逻辑见 Backend/rag/llm_provider.py）
LLM_PROVIDER=hunyuan

HUNYUAN_API_KEY=
HUNYUAN_API_BASE=https://tokenhub.tencentmaas.com/v1
HUNYUAN_MODEL=
# 逗号分隔的候选模型 id（与混元控制台一致即可；留空则使用服务端默认列表）
HUNYUAN_MODEL_OPTIONS=

LLM_HTTP_TIMEOUT=120
LLM_MAX_TOKENS=1024
LLM_MAX_RETRIES=1

# Mail (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@campus.edu
SMTP_USE_TLS=true

# Startup behavior（正式演示可改为 false，避免重复写入种子用户）
SEED_DEFAULT_USERS=true

# NER / 实体抽取（首次运行会自动下载到 NER_MODEL_NAME；源仓库见 NER_REMOTE_MODEL）
NER_ENABLED=true
NER_MODEL_NAME=Backend/Models/ner/tiny-bert-ner
NER_REMOTE_MODEL=ckiplab/bert-tiny-chinese-ner
NER_DEVICE=cpu
NER_MAX_CHARS_PER_SEG=600
NER_LOCATION_MATCH_MODE=normalized
NER_LOCATION_DICTIONARY_PATH=Data/location_hyper.txt
# HF_ENDPOINT=https://hf-mirror.com
# TRANSFORMERS_CACHE=Backend/Models/ner_cache

