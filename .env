# ==========================================
#  SMTP 邮件发送配置（示例占位）
# ==========================================
SMTP_HOST=smtp.126.com
SMTP_PORT=465
SMTP_USER=ChaoTangAI@126.com
SMTP_PASSWORD=EXkst34DQguXMjjx
SMTP_FROM=ChaoTangAI@126.com
SMTP_USE_TLS=false

# ==========================================
#  数据库配置
# ==========================================
# SQL Server（关系数据：用户/课表/日志等）
# Windows 认证（Trusted_Connection=yes），无需用户名密码
DATABASE_URI=mssql+pyodbc://localhost/campusqa
# 全项目向量存储维数（Chroma / SQL Server VECTOR / pgvector一致；句向量更短会补零）
VECTOR_STORAGE_DIM=512
SQL_SERVER_VECTOR_DIM=512
PGVECTOR_DIM=512
# ==========================================
#  向量存储模式（chroma | postgres）
# ==========================================
STORAGE_MODE=chroma

# ==========================================
#  JWT 安全配置
# ==========================================
JWT_SECRET_KEY=8xQ7sL9zK2pR5tU8wE3yA6dF9gH2jK5lS8dF2gH5jK8lZ1xC4vB7nM9pQ2sW5eR7yU
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES=1800
JWT_REFRESH_TOKEN_EXPIRES=604800

# ==========================================
#  管理端二级密码（PBKDF2 哈希；弹窗/请求头填对应明文口令）
# ==========================================
ADMIN_SECONDARY_PASSWORD_HASH=N4A/t+7Y9DQeUAQJZeZUS3jE9drLd1PNihr0ZmiT5PasxdOC+BtasyIkxL8hqylY

# ==========================================
#  LLM API
#  - 默认 hunyuan：走腾讯混元 TokenHub（HUNYUAN_API_*）
#  - LLM_PROVIDER=auto：有混元密钥且 HUNYUAN_MODEL 留空时默认 HUNYUAN_MODEL_OPTIONS 首项
# ==========================================
LLM_PROVIDER=hunyuan

# 腾讯混元（TokenHub OpenAI 兼容；密钥仅本地填写，勿提交仓库）
HUNYUAN_API_KEY=sk-8sVCm2QEnhseHVRt9WjdkpYRlpkzEMQ96FtkA0Wjicpw0pdy
HUNYUAN_API_BASE=https://tokenhub.tencentmaas.com/v1
# TokenHub：model 须与官方一致（全小写等）；错写如 GLM-5-Turbo / MiniMax-M2.7 会 500 not found
# 下列 ID 摘自 tokenhub 文档示例；首项为默认模型，可按账号开通情况删减
HUNYUAN_MODEL_OPTIONS=hunyuan-2.0-instruct-20251111,glm-5-turbo,hunyuan-2.0-thinking-20251109,minimax-m2.5,minimax-m2.7,glm-5,deepseek-v3.2,deepseek-v3.1-terminus,deepseek-r1-0528,deepseek-v3-0324

LLM_MAX_TOKENS=1024
LLM_HTTP_TIMEOUT=360
LLM_MAX_RETRIES=1
RAG_FAST_MODE=true
RAG_VECTOR_TOP_K=2
RAG_RETRIEVAL_FUTURE_TIMEOUT=45
RAG_MAX_PROCESS_SECONDS=75
RAG_VALIDATION_NO_RETRY=true
RAG_SKIP_VALIDATION_ON_FALLBACK=true
RAG_SKIP_LLM_VALIDATION=true
RAG_SKIP_MINISTRY_RITES_VALIDATION=true

# Embedding model (local-first, fallback to remote name)
EMBEDDING_MODEL_DIR=Backend/Models/embedding/bge-small-zh-v1.5
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_HF_ENDPOINT=https://hf-mirror.com
EMBEDDING_REMOTE_DOWNLOAD_ENABLED=true

# NER model (local-first)
NER_ENABLED=true
NER_MODEL_NAME=Backend/Models/ner/tiny-bert-ner
NER_LOCATION_DICTIONARY_PATH=Data/location_hyper.txt
NER_LOCATION_MATCH_MODE=normalized
NER_DEVICE=cpu
NER_MAX_CHARS_PER_SEG=600

# Added by bootstrap_env.py (run_server.bat)
HF_ENDPOINT=https://hf-mirror.com
TRANSFORMERS_CACHE=D:\model2\Campus-Qa-System\Backend\Models\ner_cache
NER_REMOTE_MODEL=ckiplab/bert-tiny-chinese-ner
